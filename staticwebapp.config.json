{
  "routes": [
    {
      "route": "/profiles/:name",
      "rewrite": "/profiles/:name.html"
    }
  ],
  "trailingSlash": "auto",
  "navigationFallback": {
    "rewrite": "/404.html",
    "exclude": ["/assets/*", "/*.html"]
  },
  "responseOverrides": {
    "404": {
      "rewrite": "/404.html"
    }
  }
}
